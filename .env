# ── Authentification application ──────────────────────────────────────────────
USERNAME=admin
PASSWORD=admin
SECRET_KEY=lpo_ai_secret_change_in_production_2024

# ── Base de données ───────────────────────────────────────────────────────────
# dev  : sqlite:///data/sensitive_areas.db (laisser vide pour ce défaut)
# prod : postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///data/sensitive_areas.db
DB_READ_ONLY=true
DB_MAX_ROWS=5000

# ── IA (changement de provider = AI_PROVIDER + AI_MODEL) ──────────────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
AI_TEMPERATURE=0.0

# Renseigner uniquement la clé du provider actif
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
